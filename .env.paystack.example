# Paystack Configuration
# Get these from your Paystack Dashboard at https://dashboard.paystack.com/#/settings/developer

# Test Keys (for development)
PAYSTACK_PUBLIC_KEY=pk_test_your_test_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key_here

# Live Keys (for production)
# PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key_here
# PAYSTACK_SECRET_KEY=sk_live_your_live_secret_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhook Configuration
# Set this URL in your Paystack Dashboard webhook settings:
# http://localhost:3000/api/payment/webhook (for development)
# https://yourdomain.com/api/payment/webhook (for production)

# Payment Configuration
PAYMENT_CURRENCY=NGN
DEPOSIT_PERCENTAGE=20
MIN_DEPOSIT_AMOUNT=500
MAX_DEPOSIT_AMOUNT=10000